# Copy to server/.env and fill in to enable the AI query layer (Chat tab).
# Without a key, all other features work; only /api/chat is disabled.

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# The model itself is NOT an env var — it's configured at runtime from the
# Settings page (/settings, backed by GET/PUT /api/ai-settings), which stores
# up to 3 candidate OpenRouter model slugs per role (Question AI, Plan AI)
# with one marked active. Defaults to deepseek/deepseek-v4-flash.

# Optional overrides
# GARMIN_DB_PATH=/path/to/garmin_sync.db
# EVENTS_DB_PATH=visualiser-events.db
# PORT=3001
